{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Npgsql": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Dsql": {
    "ClusterEndpoint": "",
    "TokenRefreshMinutes": 1,
    "TokenExpiryMinutes": 15,
    "TokenRefreshBufferMinutes": 2,
    "CommandTimeoutSeconds": 30,
